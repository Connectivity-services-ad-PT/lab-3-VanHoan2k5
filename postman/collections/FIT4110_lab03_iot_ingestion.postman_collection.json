  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Post valid reading",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 400\", function () {\r",
                  "    pm.expect([200, 400]).to.include(pm.response.code);\r",
                  "});\r",
                  "pm.test(\"Response checking if body is present\", function () {\r",
                  "    if (pm.response.text()) {\r",
                  "        const json = pm.response.json();\r",
                  "        pm.expect(json).to.be.an('object');\r",
                  "    }\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\n  \"correlationId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babd\",\n  \"timestamp\": \"2026-05-22T13:00:00Z\",\n  \"deviceId\": \"SENSOR-TEMP-001\",\n  \"zoneId\": \"ZONE-BLOCK-A\",\n  \"eventData\": {\n    \"eventType\": \"sensor.reading.created\",\n    \"sensorType\": \"temperature\",\n    \"value\": 28.5,\n    \"unit\": \"celsius\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/telemetry/mock-check",
              "host": [ "{{baseUrl}}" ],
              "path": [ "telemetry", "mock-check" ]
            }
          },
          "response": []
        }
      ]
