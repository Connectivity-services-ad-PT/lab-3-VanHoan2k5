    "name": "FIT4110_lab03_iot_ingestion",
    "description": "FIT4110 Lab 03 Collection JSON",
    "schema": "https://getpostman.com"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Post valid reading",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 or 400 for mock check\", function () {\r",
                  "    pm.expect([201, 400]).to.include(pm.response.code);\r",
                  "});\r",
                  "pm.test(\"Response checking if body is present\", function () {\r",
                  "    if (pm.response.text()) {\r",
                  "        const json = pm.response.json();\r",
                  "        pm.expect(json).to.be.an('object');\r",
                  "    }\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sensorId\": \"SENSOR-XYZ-01\",\n  \"value\": 25.5,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/telemetry/mock-check",
              "host": [ "{{baseUrl}}" ],
              "path": [ "telemetry", "mock-check" ]
            }
          },
          "response": []
        }
      ]
    },
